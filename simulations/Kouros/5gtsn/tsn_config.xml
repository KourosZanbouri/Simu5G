<config>
    <!-- 
      1. Static Route for TSN Device 
         Traffic to Any Network (0.0.0.0/0) -> Gateway (192.168.1.1)
         Interface: eth0
    -->
    <route hosts="tsnDevice1" destination="0.0.0.0" netmask="0.0.0.0" gateway="192.168.1.1" interface="eth0" />

    <!-- 
      2. General Autoconfiguration Rule (Required for Simu5G)
         This ensures gNB, Server, and UE Wireless interfaces still get IPs.
         We assign them from the 10.x.x.x range.
    -->
    <interface hosts="**" address="10.x.x.x" netmask="255.x.x.x"/>
</config>